# Copiar a .env.local y completar

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# URL publica de la app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Precios visibles en la UI (COP)
NEXT_PUBLIC_PRICE_MENSUAL_COP=99000
NEXT_PUBLIC_PRICE_ANUAL_COP=990000

# === Stripe ===
# Crear productos en https://dashboard.stripe.com/products
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MENSUAL=price_...
STRIPE_PRICE_ID_ANUAL=price_...

# === Wompi (Colombia) ===
# https://docs.wompi.co
WOMPI_PRIVATE_KEY=prv_test_...
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=pub_test_...
WOMPI_INTEGRITY_SECRET=test_events_...
WOMPI_API_URL=https://sandbox.wompi.co/v1

# Precios Wompi (COP, sin decimales)
SUBSCRIPTION_PRICE_MENSUAL_COP=99000
SUBSCRIPTION_PRICE_ANUAL_COP=990000
